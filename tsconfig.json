{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["ES2022"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"noEmit": true,
		"paths": {
			"@/lib/*": ["./registry/default/lib/*"],
			"@/components/*": ["./src/components/*"],
			"@/hooks/*": ["./src/hooks/*"]
		}
	},
	"include": ["registry/**/*.ts", "scripts/**/*.ts"]
}
